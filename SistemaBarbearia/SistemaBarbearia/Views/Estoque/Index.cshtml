@model IEnumerable<SistemaBarbearia.Models.ProdutoModel>

@{
    ViewData["Title"] = "Controle de Estoque";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white">📦 Controle de Estoque</h2>
        <a asp-controller="Estoque" asp-action="Criar" class="btn btn-success fw-bold shadow-sm">➕ Novo Produto</a>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success fw-bold">@TempData["Sucesso"]</div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger fw-bold">@TempData["Erro"]</div>
    }

    <div class="card shadow bg-white">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 text-center align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Foto</th>
                        <th>Produto</th>
                        <th>Categoria</th>
                        <th>Custo</th>
                        <th>Venda</th>
                        <th>Estoque Atual</th>
                        <th>Status</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="8" class="py-4 text-muted fw-bold">Nenhum produto cadastrado.</td></tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="@(item.QuantidadeEstoque <= item.AlertaEstoqueBaixo ? "table-danger" : "")">
                                <td>
                                    @if (!string.IsNullOrEmpty(item.FotoCaminho))
                                    {
                                        <img src="@item.FotoCaminho" width="45" height="45" class="rounded-circle shadow-sm border border-secondary" style="object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <span class="fs-3">📦</span>
                                    }
                                </td>

                                <td class="fw-bold text-start ps-2">@item.Nome</td>
                                <td><span class="badge bg-secondary">@item.Categoria</span></td>
                                <td class="text-danger">R$ @item.PrecoCusto.ToString("F2")</td>
                                <td class="text-success fw-bold">R$ @item.PrecoVenda.ToString("F2")</td>
                                <td class="fs-5 fw-bold">@item.QuantidadeEstoque</td>
                                <td>
                                    @if (item.QuantidadeEstoque <= 0)
                                    {
                                        <span class="badge bg-danger">❌ Esgotado</span>
                                    }
                                    else if (item.QuantidadeEstoque <= item.AlertaEstoqueBaixo)
                                    {
                                        <span class="badge bg-warning text-dark">⚠️ Baixo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">✅ Normal</span>
                                    }
                                </td>
                                <td>
                                    <a asp-controller="Estoque" asp-action="Vender" asp-route-id="@item.Id" class="btn btn-sm btn-success fw-bold">💰 Vender</a>
                                </td>
                            </tr>
                        <td>
                            <div class="d-flex gap-1 justify-content-center">
                                <a asp-controller="Estoque" asp-action="Vender" asp-route-id="@item.Id" class="btn btn-sm btn-success fw-bold shadow-sm">💰 Vender</a>
                                <a asp-controller="Estoque" asp-action="Reabastecer" asp-route-id="@item.Id" class="btn btn-sm btn-primary fw-bold shadow-sm">🔄 Repor</a>
                            </div>
                        </td>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>