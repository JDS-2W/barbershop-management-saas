@model SistemaBarbearia.Models.ProdutoModel

@{
    ViewData["Title"] = "Novo Produto";
}

<div class="container mt-5">
    <div class="card shadow border-warning border-2 p-4 mx-auto bg-dark text-white" style="max-width: 800px;">
        <h3 class="mb-4 text-warning fw-bold">➕ Cadastrar Novo Produto</h3>

        <form asp-controller="Estoque" asp-action="Criar" method="post" enctype="multipart/form-data">

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="fw-bold">Nome do Produto</label>
                    <input asp-for="Nome" class="form-control" placeholder="Ex: Pomada Efeito Matte 150g" required />
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Categoria</label>
                    <select asp-for="Categoria" class="form-select" required>
                        <option value="Venda">Produto para Venda (Prateleira)</option>
                        <option value="Consumo Interno">Consumo Interno (Lâmina, Gola, etc)</option>
                    </select>
                </div>
            </div>

            <div class="row mb-3 p-3 border border-secondary rounded bg-black">
                <div class="col-md-4">
                    <label class="fw-bold text-danger">Preço de Custo (Você pagou)</label>
                    <input asp-for="PrecoCusto" type="number" step="0.01" id="InputCusto" class="form-control fw-bold" required />
                </div>
                <div class="col-md-4">
                    <label class="fw-bold text-primary">Preço de Venda (Cliente paga)</label>
                    <input asp-for="PrecoVenda" type="number" step="0.01" id="InputVenda" class="form-control fw-bold" required />
                </div>
                <div class="col-md-4">
                    <label class="fw-bold text-success">💰 Lucro por Unidade</label>
                    <input type="text" id="VisorLucro" class="form-control text-success fw-bold bg-dark border-success" readonly value="R$ 0,00" />
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="fw-bold">Quantidade em Estoque</label>
                    <input asp-for="QuantidadeEstoque" type="number" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="fw-bold text-warning">Avisar quando chegar em (Mínimo):</label>
                    <input asp-for="AlertaEstoqueBaixo" type="number" class="form-control" value="5" required />
                </div>
            </div>

            <div class="mb-4">
                <label class="fw-bold">📷 Foto do Produto</label>
                <input type="file" name="fotoProduto" class="form-control bg-light" accept="image/*" />
                <small class="text-muted">Escolha uma imagem clara para facilitar a identificação.</small>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary px-4">Voltar</a>
                <button type="submit" class="btn btn-warning text-dark fw-bold px-5">Salvar Produto</button>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const inputCusto = document.getElementById("InputCusto");
        const inputVenda = document.getElementById("InputVenda");
        const visorLucro = document.getElementById("VisorLucro");

        function calcularLucro() {
            
            const custo = parseFloat(inputCusto.value) || 0;
            const venda = parseFloat(inputVenda.value) || 0;

            
            const lucro = venda - custo;

            
            if (lucro > 0) {
                visorLucro.value = "Lucro de: R$ " + lucro.toFixed(2);
                visorLucro.className = "form-control text-success fw-bold bg-dark border-success";
            } else if (lucro < 0) {
                visorLucro.value = "Prejuízo de: R$ " + Math.abs(lucro).toFixed(2);
                visorLucro.className = "form-control text-danger fw-bold bg-dark border-danger";
            } else {
                visorLucro.value = "R$ 0,00";
                visorLucro.className = "form-control text-warning fw-bold bg-dark border-warning";
            }
        }

        // Toda vez que digitar um número, o sistema refaz a conta na mesma hora
        inputCusto.addEventListener("input", calcularLucro);
        inputVenda.addEventListener("input", calcularLucro);
    });
</script>