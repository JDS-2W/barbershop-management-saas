@model SistemaBarbearia.Models.ProdutoModel

@{
    ViewData["Title"] = "Reabastecer Estoque";
}

<div class="container mt-5">
    <div class="card shadow p-4 mx-auto border-primary border-2 bg-dark text-white" style="max-width: 500px;">
        <h3 class="text-primary fw-bold text-center mb-4">🔄 Reabastecer Produto</h3>

        <div class="text-center mb-4">
            @if (!string.IsNullOrEmpty(Model.FotoCaminho))
            {
                <img src="@Model.FotoCaminho" width="100" height="100" class="rounded-circle border border-2 border-primary mb-2" style="object-fit: cover;" />
            }
            <h4 class="fw-bold">@Model.Nome</h4>
            <h5 class="text-warning">Estoque Atual: @Model.QuantidadeEstoque un</h5>
        </div>

        <form asp-controller="Estoque" asp-action="ConfirmarReabastecimento" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="caixaId" value="@ViewBag.CaixaId" />

            <div class="mb-3">
                <label class="fw-bold">Quantas unidades chegaram?</label>
                <input type="number" name="quantidadeComprada" class="form-control fs-5 text-center" value="1" min="1" required />
            </div>

            <div class="mb-4 p-3 bg-black rounded border border-danger">
                <label class="fw-bold text-danger">Qual foi o Custo Total dessa compra? (R$)</label>
                <small class="d-block text-muted mb-2">Este valor sairá do caixa atual como Despesa.</small>
                <input type="number" name="custoTotal" step="0.01" class="form-control fs-4 fw-bold text-danger" required />
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-primary fw-bold px-4">Salvar e Registrar Gasto</button>
            </div>
        </form>
    </div>
</div>