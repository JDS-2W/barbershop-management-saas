@model SistemaBarbearia.Models.ProdutoModel

@{
    ViewData["Title"] = "Checkout de Produto";
}

<div class="container mt-5">
    <div class="card shadow p-4 mx-auto border-success border-2 bg-dark text-white" style="max-width: 500px;">
        <h3 class="text-success fw-bold text-center mb-4">🛒 Finalizar Venda</h3>

        <div class="text-center mb-4">
            @if (!string.IsNullOrEmpty(Model.FotoCaminho))
            {
                <img src="@Model.FotoCaminho" width="120" height="120" class="rounded-circle border border-3 border-success mb-3 shadow" style="object-fit: cover;" />
            }
            <h4 class="fw-bold">@Model.Nome</h4>
            <h5 class="text-warning">Estoque Atual: @Model.QuantidadeEstoque un</h5>
            <h3 class="text-success mt-2 fw-bold">R$ @Model.PrecoVenda.ToString("F2") <small class="fs-6 text-muted">/cada</small></h3>
        </div>

        <form asp-controller="Estoque" asp-action="ConfirmarVenda" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="caixaId" value="@ViewBag.CaixaId" />

            <div class="mb-3">
                <label class="fw-bold">Quantas unidades o cliente está levando?</label>
                <input type="number" name="quantidade" class="form-control fs-5 text-center fw-bold" value="1" min="1" max="@Model.QuantidadeEstoque" required />
            </div>

            <div class="mb-4">
                <label class="fw-bold">Forma de Pagamento</label>
                <select name="formaPagamento" class="form-select fs-5" required>
                    <option value="PIX">💠 PIX</option>
                    <option value="Dinheiro">💵 Dinheiro</option>
                    <option value="Cartao Credito">💳 Cartão de Crédito</option>
                    <option value="Cartao Debito">💳 Cartão de Débito</option>
                </select>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-success fw-bold px-4">💰 Confirmar e Receber</button>
            </div>
        </form>
    </div>
</div>