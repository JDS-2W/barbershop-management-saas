<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Jadson Barber</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        html, body {
            background-color: #0A0A0A !important;
            color: #FFFFFF !important;
            margin: 0;
            padding: 0;
        }

        .navbar-premium {
            background-color: #000 !important;
            border-bottom: 2px solid #C6A75E;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark navbar-premium mb-3">
            <div class="container d-flex justify-content-between">
                <a class="navbar-brand font-weight-bold" style="color: #C6A75E;" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-cut"></i> JADSON BARBER
                </a>

            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted border-top border-dark text-center py-3">
        <div class="container">
            &copy; 2026 - Jadson Barber <span class="badge bg-warning text-dark">Premium Edition</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>