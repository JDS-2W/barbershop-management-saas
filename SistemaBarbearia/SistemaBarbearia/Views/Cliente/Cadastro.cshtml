@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Primeiro Acesso | Jadson Barber</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: radial-gradient(circle at center, #1a1a1a 0%, #050505 100%);
            font-family: 'Inter', sans-serif;
            color: #fff;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card-premium {
            background: rgba(22, 22, 22, 0.95);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 28px;
            padding: 50px 40px;
            width: 90%;
            max-width: 450px;
            text-align: center;
            box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        }

        .title-gold {
            font-weight: 800;
            font-size: 2rem;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

            .title-gold span {
                color: #FACC15;
            }

        .subtitle {
            color: rgba(255,255,255,0.5);
            font-size: 0.9rem;
            margin-bottom: 35px;
            display: block;
        }

        .form-group {
            text-align: left;
            margin-bottom: 20px;
        }

        label {
            font-size: 0.7rem;
            font-weight: 700;
            color: #FACC15;
            text-transform: uppercase;
            margin-bottom: 8px;
            display: block;
            letter-spacing: 1px;
        }

        input {
            background: #000 !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            color: #fff !important;
            border-radius: 12px;
            padding: 18px;
            font-size: 1rem;
            width: 100%;
            transition: 0.3s;
        }

            input:focus {
                border-color: #FACC15 !important;
                outline: none;
                box-shadow: 0 0 15px rgba(250, 204, 21, 0.2);
            }

        .btn-gold {
            background: linear-gradient(90deg, #FACC15, #EAB308);
            color: #000;
            border-radius: 50px;
            font-weight: 800;
            border: none;
            padding: 20px;
            width: 100%;
            text-transform: uppercase;
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-top: 15px;
        }

            .btn-gold:hover {
                transform: translateY(-3px);
                box-shadow: 0 15px 30px rgba(250, 204, 21, 0.4);
            }
    </style>
</head>
<body>

    <div class="card-premium">
        <h2 class="title-gold">PRIMEIRO <span>ACESSO</span></h2>
        <span class="subtitle">Cadastre-se para agendar seu horário.</span>

        <form action="/Cliente/Salvar" method="post">
            <div class="form-group">
                <label>Nome Completo</label>
                <input type="text" name="Nome" placeholder="Ex: Jadson Silva" required>
            </div>

            <div class="form-group">
                <label>WhatsApp</label>
                <input type="text" name="WhatsApp" id="whatsapp" placeholder="(00) 00000-0000" required>
            </div>

            <button type="submit" class="btn-gold">
                CADASTRAR E CONTINUAR <i class="fas fa-arrow-right"></i>
            </button>
        </form>
    </div>

    <script>
        const tel = document.getElementById('whatsapp');
        tel.addEventListener('input', (e) => {
            let v = e.target.value.replace(/\D/g, "");
            v = v.replace(/^(\d{2})(\d)/g, "($1) $2");
            v = v.replace(/(\d)(\d{4})$/, "$1-$2");
            e.target.value = v;
        });
    </script>
</body>
</html>