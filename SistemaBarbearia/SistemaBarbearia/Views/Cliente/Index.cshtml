@{
    ViewData["Title"] = "Login Admin";
}

<div class="container py-5 d-flex justify-content-center">
    <div class="card-saas w-100 p-4" style="max-width: 400px; background: #1C1C1C; border: 1px solid #C6A75E; border-radius: 15px;">

        <div class="text-center mb-4">
            <i class="fas fa-lock fa-3x mb-2" style="color: #FACC15;"></i>
            <h2 class="text-white">PAINEL ADMIN</h2>
        </div>

        <form asp-controller="Login" asp-action="Entrar" method="post">

            <div class="mb-3">
                <label class="text-white small">Usuário / WhatsApp</label>
                <input type="text" name="whatsapp" class="form-control" placeholder="admin ou número" required />
            </div>

            <div class="mb-3">
                <label class="text-white small">Senha</label>
                <input type="password" name="senha" class="form-control" placeholder="****" required />
            </div>

            <button type="submit" class="btn btn-warning w-100" style="background-color: #FACC15; font-weight: bold; border: none;">ENTRAR</button>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mt-3" style="font-size: 0.8rem; background-color: rgba(220, 53, 69, 0.1); border: 1px solid #dc3545; color: #ff6b6b;">
                    @Html.ValidationSummary(true)
                </div>
            }
        </form>

        <div class="text-center mt-4">
            <a asp-controller="Home" asp-action="Index" class="small text-secondary text-decoration-none">
                <i class="fas fa-arrow-left"></i> Voltar para o início
            </a>
        </div>
    </div>
</div>