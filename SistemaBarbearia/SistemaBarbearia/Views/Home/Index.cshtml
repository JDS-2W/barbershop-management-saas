@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#050505">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

    <title>Jadson Barber | App</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --gold: #FACC15;
            --gold-dark: #C6A75E;
            --glass-bg: rgba(15, 15, 15, 0.5);
            --glass-border: rgba(255, 255, 255, 0.1);
        }

        body {
            /**/
            background: linear-gradient(to bottom, rgba(0, 0, 0, 0.8) 0%, rgba(5, 5, 5, 1) 100%), url('https://images.unsplash.com/photo-1503951914875-452162b0f3f1?q=80&w=2070&auto=format&fit=crop') no-repeat center top fixed;
            background-size: cover;
            font-family: 'Inter', sans-serif;
            color: #ffffff;
            margin: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
            -webkit-tap-highlight-color: transparent; 
        }

        /* --- MENU SUPERIOR MOBILE --- */
        .navbar-mobile {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 6%;
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-bottom: 1px solid rgba(255,255,255,0.05);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .brand {
            font-weight: 900;
            font-size: 1.3rem;
            letter-spacing: -1px;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .brand i {
                color: var(--gold);
                font-size: 1.5rem;
            }

            .brand span {
                color: var(--gold);
            }

        .btn-nav-login {
            background: rgba(255,255,255,0.1);
            color: #fff;
            padding: 8px 16px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.85rem;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 6px;
            border: 1px solid rgba(255,255,255,0.1);
        }

        /* --- ÁREA PRINCIPAL --- */
        .hero {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 40px 6% 20px 6%;
            animation: fadeIn 1s ease;
        }

        .badge-premium {
            background: rgba(250, 204, 21, 0.1);
            color: var(--gold);
            padding: 6px 12px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 800;
            letter-spacing: 1px;
            text-transform: uppercase;
            display: inline-block;
            margin-bottom: 15px;
            border: 1px solid rgba(250, 204, 21, 0.2);
            align-self: flex-start;
        }

        .hero-title {
            font-size: 2.4rem; /* Tamanho perfeito para celular */
            font-weight: 900;
            line-height: 1.1;
            letter-spacing: -1px;
            margin: 0 0 15px 0;
        }

        .hero-subtitle {
            color: rgba(255,255,255,0.7);
            font-size: 1rem;
            margin-bottom: 30px;
            line-height: 1.5;
            font-weight: 400;
        }

        /* --- BOTÕES OTIMIZADOS PARA O POLEGAR --- */
        .btn-primary-gold {
            background: linear-gradient(90deg, #FACC15, #EAB308);
            color: #000;
            width: 100%;
            padding: 18px;
            border-radius: 16px; 
            font-weight: 800;
            text-decoration: none;
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 10px 25px rgba(250, 204, 21, 0.2);
            text-transform: uppercase;
            margin-bottom: 15px;
        }

            .btn-primary-gold:active {
                transform: scale(0.98);
            }

        .secondary-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            width: 100%;
        }

        .btn-secondary-glass {
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            color: #fff;
            padding: 15px 10px;
            border-radius: 14px;
            font-weight: 600;
            text-decoration: none;
            font-size: 0.9rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

            .btn-secondary-glass i {
                font-size: 1.2rem;
                color: var(--gold);
            }

            .btn-secondary-glass:active {
                background: rgba(255,255,255,0.1);
            }

        /* --- CARROSSEL DE VANTAGENS (SWIPE) --- */
        .features-slider {
            display: flex;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            padding: 10px 6% 30px 6%;
            gap: 15px;
            -webkit-overflow-scrolling: touch; 
            scrollbar-width: none; 
        }

            .features-slider::-webkit-scrollbar {
                display: none;
            }
        

        .feature-card {
            min-width: 75vw; 
            scroll-snap-align: start;
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            padding: 20px;
            border-radius: 18px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .feature-icon {
            background: rgba(250, 204, 21, 0.1);
            color: var(--gold);
            width: 45px;
            height: 45px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
        }

        .feature-text h4 {
            margin: 0;
            font-size: 1rem;
            font-weight: 800;
            color: #fff;
        }

        .feature-text p {
            margin: 0;
            color: rgba(255,255,255,0.6);
            font-size: 0.85rem;
            line-height: 1.4;
        }

        /* --- RODAPÉ DISCRETO --- */
        .footer-saas {
            text-align: center;
            padding: 20px 6%;
            border-top: 1px solid rgba(255,255,255,0.05);
            font-size: 0.75rem;
            color: rgba(255,255,255,0.3);
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: auto;
        }

        .btn-admin {
            color: rgba(255,255,255,0.4);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(15px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        
        @@media (min-width: 768px) {
            .hero {
                padding: 60px 15%;
                align-items: center;
                text-align: center;
            }

            .badge-premium {
                align-self: center;
            }

            .hero-title {
                font-size: 4rem;
            }

            .secondary-actions {
                grid-template-columns: 1fr 1fr;
                width: 60%;
                margin: 0 auto;
            }

            .btn-primary-gold {
                width: 60%;
                margin: 0 auto 15px auto;
            }

            .features-slider {
                justify-content: center;
                overflow-x: visible;
            }

            .feature-card {
                min-width: 250px;
            }
        }
    </style>
</head>
<body>

    <nav class="navbar-mobile">
        <div class="brand">
            <i class="fas fa-scissors"></i> Jadson<span>Barber</span>
        </div>
        <a asp-controller="Login" asp-action="Index" class="btn-nav-login">
            <i class="fas fa-user-circle"></i> Entrar
        </a>
    </nav>

    <section class="hero">
        <div class="badge-premium">Padrão Premium</div>
        <h1 class="hero-title">O SEU ESTILO<br>NO PRÓXIMO NÍVEL.</h1>
        <p class="hero-subtitle">
            Esqueça as filas. Agende seu horário em poucos toques e garanta o seu visual com a nossa equipe de especialistas.
        </p>

        <a asp-controller="Agendamento" asp-action="Criar" class="btn-primary-gold">
            <i class="fas fa-calendar-check"></i> AGENDAR AGORA
        </a>

        <div class="secondary-actions">
            <a asp-controller="Agendamento" asp-action="Listagem" class="btn-secondary-glass">
                <i class="fas fa-list-ul"></i>
                <span>Ver Horários</span>
            </a>
            <a asp-controller="Login" asp-action="Cadastrar" class="btn-secondary-glass">
                <i class="fas fa-user-plus"></i>
                <span>Criar Conta</span>
            </a>
        </div>
    </section>

    <div class="features-slider">
        <div class="feature-card">
            <div class="feature-icon"><i class="fas fa-bolt"></i></div>
            <div class="feature-text">
                <h4>Zero Fila de Espera</h4>
                <p>Seu tempo é precioso. Chegue e sente na cadeira na hora marcada.</p>
            </div>
        </div>
        <div class="feature-card">
            <div class="feature-icon"><i class="fas fa-star"></i></div>
            <div class="feature-text">
                <h4>Cortes de Elite</h4>
                <p>Especialistas em degradê perfeito, clássicos e barba na toalha quente.</p>
            </div>
        </div>
        <div class="feature-card">
            <div class="feature-icon"><i class="fas fa-glass-whiskey"></i></div>
            <div class="feature-text">
                <h4>Ambiente Exclusivo</h4>
                <p>Música de qualidade, ar condicionado trincando e conforto máximo.</p>
            </div>
        </div>
    </div>

    <footer class="footer-saas">
        <a asp-controller="Login" asp-action="Admin" class="btn-admin">
            <i class="fas fa-lock"></i> Acesso Restrito ao Painel
        </a>
        <span>&copy; 2026 Jadson Barber SaaS</span>
    </footer>

</body>
</html>