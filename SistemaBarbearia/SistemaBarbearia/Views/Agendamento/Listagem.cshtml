@model IEnumerable<SistemaBarbearia.Models.AgendamentoModel>
@{
    Layout = null;
    // Pega o WhatsApp do primeiro item ou da QueryString para manter o vínculo
    var whatsappCliente = Context.Request.Query["whatsapp"].ToString();

    //  Agrupa os agendamentos pela data para criar os separadores
    var agendamentosAgrupados = Model.GroupBy(a => a.Data.Date);
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#050505">
    <title>Minhas Reservas | Jadson Barber</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --gold: #FACC15;
            --app-bg: #050505;
            --card-bg: #121212;
            --border: rgba(255,255,255,0.08);
        }

        body {
            background-color: var(--app-bg);
            font-family: 'Inter', sans-serif;
            color: #fff;
            margin: 0;
            padding: 0;
            padding-bottom: 100px; /**/
        }

        /* HEADER ESTILO APP */
        .app-header {
            background: rgba(10, 10, 10, 0.95);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            padding: 20px;
            display: flex;
            align-items: center;
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .btn-back {
            color: #fff;
            text-decoration: none;
            font-size: 1.2rem;
            margin-right: 15px;
        }

        .app-header h1 {
            font-size: 1.1rem;
            font-weight: 800;
            margin: 0;
            letter-spacing: -0.5px;
            text-transform: uppercase;
        }

        /* CONTEÚDO */
        .container {
            padding: 20px;
        }

        .welcome-text {
            margin-bottom: 10px;
        }

            .welcome-text h2 {
                font-size: 1.5rem;
                font-weight: 900;
                margin: 0;
                color: var(--gold);
            }

            .welcome-text p {
                font-size: 0.9rem;
                color: rgba(255,255,255,0.5);
                margin-top: 5px;
            }

        /* SEPARADOR DE DATA */
        .data-header {
            font-size: 1.1rem;
            font-weight: 800;
            color: var(--gold);
            margin: 35px 0 15px 0;
            display: flex;
            align-items: center;
            gap: 10px;
            text-transform: capitalize;
            border-bottom: 1px solid var(--border);
            padding-bottom: 10px;
        }

            .data-header i {
                font-size: 1.2rem;
                color: #fff;
            }

            .data-header .dia-semana {
                color: rgba(255,255,255,0.4);
                font-size: 0.85rem;
                font-weight: 600;
                text-transform: uppercase;
            }

        /* CARD DE AGENDAMENTO */
        .reserva-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

            .reserva-card::before {
                content: '';
                position: absolute;
                left: 0;
                top: 0;
                bottom: 0;
                width: 4px;
                background: var(--gold);
            }

        .reserva-info h3 {
            font-size: 1.1rem;
            font-weight: 800;
            margin: 0 0 8px 0;
        }

        .reserva-details {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .detail-item {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.6);
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .detail-item i {
                color: var(--gold);
                width: 14px;
            }

        /* BADGES DE STATUS */
        .status-area {
            text-align: right;
        }

        .status-badge {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 10px;
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .status-pendente {
            background: rgba(250, 204, 21, 0.1);
            color: var(--gold);
        }

        .status-concluido {
            background: rgba(34, 197, 94, 0.1);
            color: #22c55e;
        }

        .status-falta {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
        }

        /* EMPTY STATE (Quando não tem nada) */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: rgba(255,255,255,0.2);
        }

            .empty-state i {
                font-size: 4rem;
                margin-bottom: 15px;
            }

            .empty-state p {
                font-size: 1rem;
                font-weight: 600;
            }

        /* BOTÃO FLUTUANTE "NOVO" */
        .btn-float {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--gold);
            color: #000;
            padding: 18px 40px;
            border-radius: 50px;
            font-weight: 900;
            font-size: 1rem;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 10px 30px rgba(250, 204, 21, 0.3);
            width: 70%;
            justify-content: center;
            z-index: 1000;
            transition: 0.3s;
        }

            .btn-float:active {
                transform: translateX(-50%) scale(0.95);
            }

    </style>
</head>
<body>

    <div class="app-header">
        <a href="/" class="btn-back"><i class="fas fa-chevron-left"></i></a>
        <h1>Minhas Reservas</h1>
    </div>

    <div class="container">
        <div class="welcome-text">
            <h2>Olá! 👋</h2>
            <p>Confira abaixo seus horários agendados.</p>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="fas fa-calendar-times"></i>
                <p>Você ainda não possui<br>agendamentos marcados.</p>
            </div>
        }
        else
        {
            //repete os cartões AGRUPADOS por dia
            @foreach (var grupo in agendamentosAgrupados)
            {
                <div class="data-header">
                    <i class="far fa-calendar-check"></i>
                    @grupo.Key.ToString("dd 'de' MMMM", new System.Globalization.CultureInfo("pt-BR"))
                    <span class="dia-semana">- @grupo.Key.ToString("dddd", new System.Globalization.CultureInfo("pt-BR"))</span>
                </div>

                @foreach (var item in grupo)
                {
                    <div class="reserva-card">
                        <div class="reserva-info">
                            <h3>@item.Servico</h3>
                            <div class="reserva-details">

                                <div class="detail-item">
                                    <i class="fas fa-user"></i>
                                    @item.NomeCliente
                                </div>
                                <div class="detail-item">
                                    <i class="far fa-clock"></i>
                                    <span style="font-weight: 700; color: #fff;">@item.Horario</span>
                                </div>
                                <div class="detail-item">
                                    <i class="fas fa-user-tie"></i>
                                    @item.Profissional
                                </div>
                            </div>
                        </div>
                        <div class="status-area">
                            @if (item.IsConcluido)
                            {
                                <span class="status-badge status-concluido">Finalizado</span>
                            }
                            else if (item.IsFalta)
                            {
                                <span class="status-badge status-falta">Não Compareceu</span>
                            }
                            else
                            {
                                <span class="status-badge status-pendente">Confirmado</span>
                            }
                        </div>
                    </div>
                }
            }
        }
    </div>

    <a href="/Agendamento/Criar?whatsapp=@whatsappCliente" class="btn-float">
        <i class="fas fa-plus"></i> NOVO AGENDAMENTO
    </a>

</body>
</html>