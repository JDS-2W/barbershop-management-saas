@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#050505">
    <title>Jadson Barber | Agendamento</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --gold: #FACC15;
            --gold-dark: #C6A75E;
            --bg-dark: #050505;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-dark);
            color: #fff;
            height: 100vh;
            overflow: hidden; /* Evita scroll desnecessário na entrada */
            display: flex;
            justify-content: center;
        }

        /**/
        .hero-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(5,5,5,1)), url('https://images.unsplash.com/photo-1503951914875-452162b0f3f1?q=80&w=2070&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            z-index: -1;
        }

        .main-container {
            width: 100%;
            max-width: 450px;
            padding: 40px 25px;
            display: flex;
            flex-direction: column;
            justify-content: flex-end; /**/
            height: 100%;
            padding-bottom: 60px;
        }

        /**/
        .brand-area {
            text-align: left;
            margin-bottom: 40px;
        }

            .brand-area i {
                font-size: 3.5rem;
                color: var(--gold);
                margin-bottom: 20px;
                filter: drop-shadow(0 0 15px rgba(250, 204, 21, 0.4));
            }

            .brand-area h1 {
                font-size: 2.8rem;
                font-weight: 900;
                line-height: 1.1;
                letter-spacing: -1.5px;
                margin-bottom: 10px;
            }

                .brand-area h1 span {
                    color: var(--gold);
                }

            .brand-area p {
                font-size: 1.1rem;
                color: rgba(255,255,255,0.7);
                font-weight: 400;
            }

        /* Formulário de Acesso */
        .login-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 30px;
            padding: 30px 20px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        }

        .input-wrapper {
            position: relative;
            margin-bottom: 20px;
        }

            .input-wrapper i {
                position: absolute;
                left: 20px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--gold);
                font-size: 1.2rem;
            }

            .input-wrapper input {
                width: 100%;
                background: rgba(255, 255, 255, 0.08);
                border: 1px solid rgba(255, 255, 255, 0.1);
                padding: 22px 20px 22px 55px;
                border-radius: 20px;
                color: #fff;
                font-size: 1.1rem;
                font-weight: 500;
                transition: 0.3s;
            }

                .input-wrapper input:focus {
                    outline: none;
                    border-color: var(--gold);
                    background: rgba(255, 255, 255, 0.12);
                    box-shadow: 0 0 20px rgba(250, 204, 21, 0.1);
                }

        .btn-primary {
            width: 100%;
            background: var(--gold);
            color: #000;
            padding: 22px;
            border-radius: 20px;
            border: none;
            font-weight: 900;
            font-size: 1.1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            box-shadow: 0 10px 25px rgba(250, 204, 21, 0.3);
        }

            .btn-primary:active {
                transform: scale(0.96);
                background: var(--gold-dark);
            }

        .info-footer {
            margin-top: 25px;
            font-size: 0.85rem;
            color: rgba(255,255,255,0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        /* Ajuste para teclados de celular */
        @@media (max-height: 650px) {
            .brand-area i {
                font-size: 2.5rem;
                margin-bottom: 10px;
            }

            .brand-area h1 {
                font-size: 2rem;
            }

            .main-container {
                justify-content: center;
                padding-top: 40px;
            }
        }
    </style>
</head>
<body>

    <div class="hero-bg"></div>

    <div class="main-container">
        <div class="brand-area">
            <i class="fas fa-crown"></i>
            <h1>Jadson<br><span>Barber</span></h1>
            <p>O estilo que você merece,<br>no tempo que você precisa.</p>
        </div>

        <div class="login-card">
            <form asp-action="VerificarWhatsapp" method="post">
                <div class="input-wrapper">
                    <i class="fab fa-whatsapp"></i>
                    <input type="tel" name="whatsapp" placeholder="Digite seu WhatsApp" required autofocus>
                </div>

                <button type="submit" class="btn-primary">
                    Acessar Agenda <i class="fas fa-arrow-right"></i>
                </button>
            </form>

            <div class="info-footer">
                <i class="fas fa-lock"></i>
                Seus dados estão seguros
            </div>
        </div>
    </div>

    <script>
        const input = document.querySelector('input[name="whatsapp"]');
        input.addEventListener('keyup', (e) => {
            let val = e.target.value.replace(/\D/g, '');
            if (val.length > 11) val = val.slice(0, 11);
            e.target.value = val;
        });
    </script>

</body>
</html>