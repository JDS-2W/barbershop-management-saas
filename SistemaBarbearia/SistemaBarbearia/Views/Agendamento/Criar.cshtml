@model SistemaBarbearia.Models.AgendamentoModel
@{
    Layout = null;
    var hoje = DateTime.Today;
    var dataSelecionadaAtiva = ViewBag.DataSelecionada != null ? (DateTime)ViewBag.DataSelecionada : hoje;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#050505">
    <title>Agendar Horário | Jadson Barber</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --gold: #FACC15;
            --gold-dark: #C6A75E;
            --app-bg: #050505;
            --card-bg: rgba(20, 20, 20, 0.85);
            --input-bg: rgba(255, 255, 255, 0.05);
            --border-color: rgba(255, 255, 255, 0.08);
        }

        body {
            /* Fundo da barbearia escurecido */
            background: linear-gradient(to bottom, rgba(0, 0, 0, 0.7), rgba(5, 5, 5, 1)), url('https://images.unsplash.com/photo-1585747860715-2ba37e788b70?q=80&w=2074&auto=format&fit=crop') no-repeat center center fixed;
            background-size: cover;
            font-family: 'Inter', sans-serif;
            color: #fff;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
            display: flex;
            justify-content: center;
        }

        /**/
        .app-container {
            width: 100%;
            max-width: 500px; /*  */
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            min-height: 100vh;
            position: relative;
            padding-bottom: 120px; /* */
            display: flex;
            flex-direction: column;
            box-shadow: 0 0 50px rgba(0,0,0,0.8);
        }

        /* --- BARRA SUPERIOR (NAVBAR) --- */
        .app-header {
            position: sticky;
            top: 0;
            background: rgba(10, 10, 10, 0.9);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--border-color);
            padding: 15px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            z-index: 100;
        }

        .btn-back {
            color: #fff;
            text-decoration: none;
            font-size: 1.2rem;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: flex-start;
        }

        .header-title {
            font-weight: 800;
            font-size: 1.1rem;
            margin: 0;
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            letter-spacing: -0.5px;
        }

        /* --- CONTEÚDO DO FORMULÁRIO --- */
        .form-content {
            padding: 25px 20px;
        }

        .section-title {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.5);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 0 0 10px 5px;
            display: block;
        }

        /* PROFISSIONAL */
        .barber-group {
            display: flex;
            gap: 12px;
            margin-bottom: 25px;
            overflow-x: auto; /**/
            padding-bottom: 5px;
        }

            /* Esconde a barra de rolagem mas mantém a função */
            .barber-group::-webkit-scrollbar {
                display: none;
            }

        .barber-group {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        .btn-barber {
            background: var(--input-bg);
            border: 1px solid var(--border-color);
            color: rgba(255,255,255,0.7);
            padding: 16px 15px;
            border-radius: 16px;
            cursor: pointer;
            transition: 0.3s;
            flex-shrink: 0; /**/
            min-width: 130px; /**/
            font-weight: 600;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

            .btn-barber.active {
                background: rgba(250, 204, 21, 0.15);
                color: var(--gold);
                border-color: var(--gold);
                box-shadow: inset 0 0 0 1px var(--gold);
            }

        /* INPUTS E SELECTS */
        .input-group {
            position: relative;
            margin-bottom: 15px;
            width: 100%;
        }

            .input-group i {
                position: absolute;
                left: 16px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--gold);
                font-size: 1.1rem;
            }

            .input-group input, .input-group select {
                width: 100%;
                background: var(--input-bg);
                border: 1px solid var(--border-color);
                color: #fff;
                padding: 18px 16px 18px 48px;
                border-radius: 16px;
                font-size: 1rem;
                font-family: 'Inter', sans-serif;
                transition: 0.3s;
                appearance: none;
            }

                .input-group input:focus, .input-group select:focus {
                    outline: none;
                    border-color: var(--gold);
                    background: rgba(0, 0, 0, 0.5);
                }

        .select-wrapper::after {
            content: '\f078';
            font-family: 'Font Awesome 5 Free';
            font-weight: 900;
            position: absolute;
            right: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.5);
            pointer-events: none;
            font-size: 0.8rem;
        }

        /* DATAS */
        .date-group {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
        }

        .btn-date {
            background: var(--input-bg);
            border: 1px solid var(--border-color);
            color: #fff;
            padding: 14px 5px;
            border-radius: 16px;
            cursor: pointer;
            transition: 0.3s;
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

            .btn-date span:first-child {
                font-size: 0.75rem;
                color: rgba(255,255,255,0.5);
                text-transform: uppercase;
                font-weight: 700;
                margin-bottom: 4px;
            }

            .btn-date span:last-child {
                font-size: 1.4rem;
                font-weight: 900;
            }

            .btn-date.active {
                background: var(--gold);
                border-color: var(--gold);
                color: #000;
                box-shadow: 0 8px 20px rgba(250, 204, 21, 0.3);
                transform: scale(1.05);
            }

                .btn-date.active span {
                    color: #000;
                }

        /* HORÁRIOS */
        .horarios-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 20px;
        }

        .btn-hora {
            background: var(--input-bg);
            border: 1px solid var(--border-color);
            color: #fff;
            padding: 15px 0;
            border-radius: 12px;
            cursor: pointer;
            font-weight: 700;
            font-size: 1rem;
            transition: 0.2s;
        }

            .btn-hora:active {
                transform: scale(0.95);
            }

            .btn-hora.active {
                background: #fff;
                color: #000;
                border-color: #fff;
                box-shadow: 0 4px 15px rgba(255,255,255,0.2);
            }

        /* MENSAGEM DE BLOQUEIO */
        .box-bloqueio {
            background: rgba(255, 59, 48, 0.1);
            border: 1px solid rgba(255, 59, 48, 0.3);
            border-radius: 16px;
            padding: 30px 20px;
            text-align: center;
            margin-bottom: 20px;
        }

            .box-bloqueio i {
                color: #ff3b30;
                font-size: 3rem;
                margin-bottom: 15px;
            }

            .box-bloqueio h5 {
                color: #ff3b30;
                font-weight: 900;
                margin: 0 0 8px 0;
                font-size: 1.2rem;
                letter-spacing: -0.5px;
            }

            .box-bloqueio p {
                color: rgba(255, 255, 255, 0.8);
                font-size: 0.95rem;
                margin: 0;
                line-height: 1.5;
            }

        /* --- BOTÃO FIXO NO RODAPÉ --- */
        .bottom-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background: rgba(10, 10, 10, 0.95);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-top: 1px solid rgba(255,255,255,0.1);
            padding: 15px 20px 25px 20px; /**/
            z-index: 1000;
            display: flex;
            justify-content: center;
        }

        .bottom-bar-inner {
            width: 100%;
            max-width: 460px; /**/
        }

        .btn-submit {
            background: linear-gradient(90deg, #FACC15, #EAB308);
            color: #000;
            width: 100%;
            padding: 20px;
            border-radius: 16px;
            border: none;
            font-weight: 900;
            font-size: 1.1rem;
            cursor: pointer;
            transition: 0.3s;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            box-shadow: 0 10px 25px rgba(250, 204, 21, 0.25);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

            .btn-submit:active {
                transform: scale(0.98);
            }

        /* Ajustes para telas maiores (PC) */
        @@media (min-width: 501px) {
            body {
                padding: 40px 0;
            }

            .app-container {
                border-radius: 30px;
                overflow: hidden;
                padding-bottom: 100px;
            }

            .bottom-bar {
                position: absolute;
                padding: 20px;
                border-radius: 0 0 30px 30px;
            }
        }
    </style>
</head>
<body>

    <div class="app-container">
        <div class="app-header">
            <a href="/" class="btn-back"><i class="fas fa-chevron-left"></i></a>
            <h1 class="header-title">Nova Reserva</h1>
            <div style="width: 40px;"></div>
        </div>

        <div class="form-content">
            <form asp-action="Criar" method="post" id="formAgendamento">

                <span class="section-title">Com quem?</span>
                <div class="barber-group">
                    @if (ViewBag.Profissionais != null)
                    {
                        var isFirst = true;
                        foreach (var prof in ViewBag.Profissionais)
                        {
                            var isActive = Model?.Profissional == prof.Nome || (string.IsNullOrEmpty(Model?.Profissional) && isFirst);

                            <button type="button" class="btn-barber @(isActive ? "active" : "")" onclick="selectBarber('@prof.Nome')">
                                <i class="fas fa-cut"></i> @prof.Nome
                            </button>

                            isFirst = false;
                        }
                    }
                    else
                    {
                        <p style="color: rgba(255,255,255,0.5); font-size: 0.8rem; padding-left: 5px;">Nenhum barbeiro disponível.</p>
                    }
                </div>
                <input type="hidden" id="Profissional" name="Profissional" value="@(Model?.Profissional ?? "")">

                <span class="section-title">Seus Dados</span>
                <div class="input-group">
                    <i class="fas fa-user"></i>
                    <input type="text" asp-for="NomeCliente" placeholder="Como devemos te chamar?" required>
                </div>
                <div class="input-group">
                    <i class="fab fa-whatsapp"></i>
                    <input type="text" asp-for="Whatsapp" placeholder="Seu WhatsApp" required readonly style="color: rgba(255,255,255,0.5);">
                </div>

                <span class="section-title">O que vamos fazer?</span>
                <div class="input-group select-wrapper mb-4">
                    <i class="fas fa-star"></i>
                    <select asp-for="Servico">
                        <option value="Corte Degradê - R$ 15">Corte Degradê - R$ 15,00</option>
                        <option value="Barba - R$ 10">Barba - R$ 10,00</option>
                        <option value="Combo - R$ 20">Corte + Barba - R$ 20,00</option>
                    </select>
                </div>

                <span class="section-title">Para quando?</span>
                <div class="date-group">
                    @for (int i = 0; i < 3; i++)
                    {
                        var dataCirculo = hoje.AddDays(i);
                        var isSelected = dataCirculo.Date == dataSelecionadaAtiva.Date;

                        <div class="btn-date @(isSelected ? "active" : "")" onclick="mudarData('@dataCirculo.ToString("yyyy-MM-dd")')">
                            <span>@dataCirculo.ToString("ddd")</span>
                            <span>@dataCirculo.ToString("dd")</span>
                        </div>
                    }
                </div>
                <input type="hidden" id="Data" name="Data" value="@dataSelecionadaAtiva.ToString("yyyy-MM-dd")">

                <span class="section-title">Qual horário?</span>

                @if (ViewBag.MotivoBloqueio != null)
                {
                    <div class="box-bloqueio">
                        <i class="fas fa-calendar-times"></i>
                        <h5>AGENDA BLOQUEADA</h5>
                        <p>@ViewBag.MotivoBloqueio</p>
                    </div>
                }
                else
                {
                    <div class="horarios-grid">
                        @if (ViewBag.HorariosDisponiveis != null)
                        {
                            foreach (var hora in (List<string>)ViewBag.HorariosDisponiveis)
                            {
                                <button type="button" class="btn-hora" onclick="selecionarHora('@hora', this)">@hora</button>
                            }
                        }
                    </div>

                    @if (ViewBag.HorariosDisponiveis == null || !((List<string>)ViewBag.HorariosDisponiveis).Any())
                    {
                        <p style="color: #ff3b30; font-size: 0.95rem; text-align: center; margin: 20px 0; font-weight: 600;">Todos os horários esgotados para esta data.</p>
                    }
                }

                <input type="hidden" id="Horario" name="Horario" required>

                @if (ViewBag.MotivoBloqueio == null)
                {
                    <div class="bottom-bar">
                        <div class="bottom-bar-inner">
                            <button type="submit" class="btn-submit" onclick="return validarHorario()">
                                Confirmar Agendamento <i class="fas fa-arrow-right"></i>
                            </button>
                        </div>
                    </div>
                }
            </form>
        </div>
    </div>

    <script>
        function mudarData(data) {
            var nome = document.getElementById('NomeCliente').value || '';
            var whatsapp = document.getElementById('Whatsapp').value || '';
            var servico = document.getElementById('Servico').value || '';
            var profissional = document.getElementById('Profissional').value || '';
            var url = '/Agendamento/Criar?dataSelecionada=' + data +
                      '&nome=' + encodeURIComponent(nome) +
                      '&whatsapp=' + encodeURIComponent(whatsapp) +
                      '&servico=' + encodeURIComponent(servico) +
                      '&profissional=' + encodeURIComponent(profissional);
            window.location.href = url;
        }

        function selecionarHora(hora, elemento) {
            document.getElementById('Horario').value = hora;
            document.querySelectorAll('.btn-hora').forEach(b => b.classList.remove('active'));
            elemento.classList.add('active');
        }

        
        function selectBarber(nome) {
            var data = document.getElementById('Data').value || '';
            var nomeCliente = document.getElementById('NomeCliente').value || '';
            var whatsapp = document.getElementById('Whatsapp').value || '';
            var servico = document.getElementById('Servico').value || '';

            var url = '/Agendamento/Criar?dataSelecionada=' + data +
                      '&nome=' + encodeURIComponent(nomeCliente) +
                      '&whatsapp=' + encodeURIComponent(whatsapp) +
                      '&servico=' + encodeURIComponent(servico) +
                      '&profissional=' + encodeURIComponent(nome);
            window.location.href = url;
        }

        function validarHorario() {
            var horarioEscolhido = document.getElementById('Horario').value;
            if (!horarioEscolhido) {
                alert("Por favor, selecione um horário antes de confirmar.");
                return false;
            }
            return true;
        }
    </script>
</body>
</html>