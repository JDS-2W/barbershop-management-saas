@model SistemaBarbearia.Models.AgendamentoModel
@{
    Layout = null;
    var hoje = DateTime.Today;
    var dataSelecionadaAtiva = ViewBag.DataSelecionada != null ? (DateTime)ViewBag.DataSelecionada : hoje;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Reserva | Jadson Barber</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --gold: #FACC15;
            --gold-dark: #C6A75E;
            --glass-bg: rgba(20, 20, 20, 0.65);
            --glass-border: rgba(250, 204, 21, 0.3);
        }

        body {
            background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.8)), url('https://images.unsplash.com/photo-1585747860715-2ba37e788b70?q=80&w=2074&auto=format&fit=crop') no-repeat center center fixed;
            background-size: cover;
            font-family: 'Inter', sans-serif;
            color: #fff;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 20px;
        }

        /* BOTÃO DE VOLTAR FLUTUANTE */
        .btn-back-home {
            position: absolute;
            top: 20px;
            left: 20px;
            color: #fff;
            text-decoration: none;
            background: rgba(0, 0, 0, 0.5);
            padding: 10px 20px;
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 600;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            transition: 0.3s;
            z-index: 1000;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .btn-back-home:hover {
                background: #FACC15;
                color: #000;
                border-color: #FACC15;
            }

        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            padding: 35px;
            width: 100%;
            max-width: 480px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.5);
            text-align: center;
        }

        .card-header {
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding-bottom: 15px;
            margin-bottom: 25px;
        }

            .card-header h2 {
                color: var(--gold);
                font-weight: 800;
                font-size: 1.4rem;
                margin: 0;
                text-transform: uppercase;
            }

        .label-saas {
            display: block;
            text-align: center;
            font-size: 0.8rem;
            color: #fff;
            margin-bottom: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .flex-row {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        .btn-select {
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: #fff;
            padding: 12px;
            border-radius: 10px;
            cursor: pointer;
            transition: 0.3s;
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
        }

            .btn-select.active {
                background: linear-gradient(90deg, #FACC15, #EAB308);
                color: #000;
                font-weight: 800;
                border-color: var(--gold);
            }

        .input-group {
            position: relative;
            margin-bottom: 15px;
            width: 100%;
        }

            .input-group i {
                position: absolute;
                left: 15px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--gold);
                font-size: 1.1rem;
            }

            .input-group input, .input-group select {
                width: 100%;
                background: rgba(0, 0, 0, 0.6);
                border: 1px solid rgba(255, 255, 255, 0.2);
                color: #fff;
                padding: 14px 14px 14px 45px;
                border-radius: 10px;
                box-sizing: border-box;
                font-size: 0.95rem;
                appearance: none;
            }

                .input-group input:focus, .input-group select:focus {
                    outline: none;
                    border-color: var(--gold);
                    background: rgba(0, 0, 0, 0.8);
                }

        .horarios-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-bottom: 25px;
            max-height: 200px;
            overflow-y: auto;
            padding-right: 5px;
        }

            .horarios-grid::-webkit-scrollbar {
                width: 5px;
            }

            .horarios-grid::-webkit-scrollbar-thumb {
                background: var(--gold);
                border-radius: 10px;
            }

        .btn-hora {
            background: rgba(0, 0, 0, 0.6);
            border: 1px solid var(--gold-dark);
            color: var(--gold);
            padding: 10px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
        }

            .btn-hora.active {
                background: linear-gradient(90deg, #FACC15, #EAB308);
                color: #000;
                border-color: var(--gold);
            }

        .btn-submit {
            background: linear-gradient(90deg, #FACC15, #EAB308);
            color: #000;
            width: 100%;
            padding: 18px;
            border-radius: 50px;
            border: none;
            font-weight: 800;
            font-size: 1.1rem;
            cursor: pointer;
            text-transform: uppercase;
        }
    </style>
</head>
<body>

    <a href="/" class="btn-back-home">
        <i class="fas fa-arrow-left"></i> INÍCIO
    </a>

    <div class="glass-card">
        <div class="card-header">
            <h2>Jadson Barber <span style="color: #fff; font-weight: 400;">|</span> Editar Reserva</h2>
        </div>

        <form asp-action="Editar" method="post">
            <input type="hidden" asp-for="Id" id="Id">

            <span class="label-saas">Escolha o Profissional</span>
            <div class="flex-row">
                <button type="button" class="btn-select @(Model?.Profissional == "Barbeiro 01" || Model?.Profissional == null ? "active" : "")" onclick="selectBarber('Barbeiro 01', this)" style="flex-direction: row;">BARBEIRO 01</button>
                <button type="button" class="btn-select @(Model?.Profissional == "Barbeiro 02" ? "active" : "")" onclick="selectBarber('Barbeiro 02', this)" style="flex-direction: row;">BARBEIRO 02</button>
            </div>
            <input type="hidden" id="Profissional" name="Profissional" value="@(Model?.Profissional ?? "Barbeiro 01")">

            <span class="label-saas">Seus Dados</span>
            <div class="input-group">
                <i class="fas fa-user"></i>
                <input type="text" asp-for="NomeCliente" placeholder="NOME COMPLETO" required>
            </div>
            <div class="input-group">
                <i class="fab fa-whatsapp"></i>
                <input type="text" asp-for="Whatsapp" placeholder="SEU WHATSAPP" required readonly style="opacity: 0.7;">
            </div>

            <span class="label-saas">O que vamos fazer?</span>
            <div class="input-group select-wrapper">
                <i class="fas fa-cut"></i>
                <select asp-for="Servico">
                    <option value="Corte Degradê - R$ 15">Corte Degradê - R$ 15</option>
                    <option value="Barba - R$ 10">Barba - R$ 10</option>
                    <option value="Combo - R$ 20">Combo - R$ 20</option>
                </select>
            </div>

            <span class="label-saas" style="margin-top: 10px;">Selecione a Data</span>
            <div class="flex-row">
                @for (int i = 0; i < 3; i++)
                {
                    var dataCirculo = hoje.AddDays(i);
                    var isSelected = dataCirculo.Date == dataSelecionadaAtiva.Date;

                    <button type="button" class="btn-select @(isSelected ? "active" : "")"
                            onclick="mudarData('@dataCirculo.ToString("yyyy-MM-dd")')">
                        <span style="font-size: 0.8rem; opacity: 0.9;">@dataCirculo.ToString("ddd").ToUpper()</span>
                        <span style="font-size: 1.1rem; font-weight: bold;">@dataCirculo.ToString("dd/MM")</span>
                    </button>
                }
            </div>
            <input type="hidden" id="Data" name="Data" value="@dataSelecionadaAtiva.ToString("yyyy-MM-dd")">

            <span class="label-saas">Horários Disponíveis</span>
            <div class="horarios-grid">
                @if (ViewBag.HorariosDisponiveis != null)
                {
                    foreach (var hora in (List<string>)ViewBag.HorariosDisponiveis)
                    {
                        var isHoraAtiva = hora == Model?.Horario ? "active" : "";
                        <button type="button" class="btn-hora @isHoraAtiva" onclick="selecionarHora('@hora', this)">@hora</button>
                    }
                }
            </div>

            <input type="hidden" id="Horario" name="Horario" value="@Model?.Horario" required>

            <button type="submit" class="btn-submit">SALVAR ALTERAÇÕES</button>
            <a href="/Agendamento/Listagem" style="display: block; margin-top: 15px; color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.9rem;">Voltar para a lista</a>
        </form>
    </div>

    <script>
        function mudarData(data) {
            var id = document.getElementById('Id').value;
            var nome = document.getElementById('NomeCliente').value || '';
            var whatsapp = document.getElementById('Whatsapp').value || '';
            var servico = document.getElementById('Servico').value || '';
            var profissional = document.getElementById('Profissional').value || 'Barbeiro 01';

            var url = '/Agendamento/Editar/' + id + '?dataSelecionada=' + data +
                      '&nome=' + encodeURIComponent(nome) +
                      '&whatsapp=' + encodeURIComponent(whatsapp) +
                      '&servico=' + encodeURIComponent(servico) +
                      '&profissional=' + encodeURIComponent(profissional);

            window.location.href = url;
        }

        function selecionarHora(hora, elemento) {
            document.getElementById('Horario').value = hora;
            document.querySelectorAll('.btn-hora').forEach(b => b.classList.remove('active'));
            elemento.classList.add('active');
        }

        function selectBarber(nome, elemento) {
            document.getElementById('Profissional').value = nome;
            elemento.parentElement.querySelectorAll('button.btn-select').forEach(b => b.classList.remove('active'));
            elemento.classList.add('active');
        }
    </script>
</body>
</html>