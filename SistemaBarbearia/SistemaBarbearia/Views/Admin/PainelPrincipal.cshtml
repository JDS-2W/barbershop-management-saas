@model List<SistemaBarbearia.Models.AgendamentoModel>

@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel de Comando | Jadson Barber</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        :root {
            --gold: #FACC15;
            --gold-dark: #EAB308;
            --bg-dark: #0a0a0a;
            --card-bg: #141414;
            --border-color: rgba(255, 255, 255, 0.05);
            --text-muted: rgba(255, 255, 255, 0.5);
        }

        body {
            background-color: var(--bg-dark);
            font-family: 'Inter', sans-serif;
            color: #fff;
            margin: 0;
            padding-bottom: 50px;
        }

        /* CABEÇALHO DO PAINEL */
        .admin-header {
            background: rgba(20, 20, 20, 0.8);
            border-bottom: 1px solid var(--border-color);
            padding: 20px 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }

        .admin-title {
            font-weight: 900;
            font-size: 1.5rem;
            margin: 0;
            letter-spacing: -0.5px;
        }

            .admin-title span {
                color: var(--gold);
            }

        .header-actions {
            display: flex;
            gap: 15px;
        }

        .btn-header {
            background: rgba(255,255,255,0.05);
            color: #fff;
            border: 1px solid var(--border-color);
            padding: 8px 16px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            transition: 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .btn-header:hover {
                background: rgba(255, 59, 48, 0.1);
                color: #ff3b30;
                border-color: rgba(255, 59, 48, 0.3);
            }

        /* CARDS FINANCEIROS */
        .dashboard-container {
            padding: 30px 5%;
        }

        .stat-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 25px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            transition: 0.3s;
            position: relative;
            overflow: hidden;
        }

            .stat-card:hover {
                transform: translateY(-5px);
                border-color: rgba(250, 204, 21, 0.3);
                box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            }

        .stat-icon {
            position: absolute;
            top: -15px;
            right: -15px;
            font-size: 5rem;
            color: rgba(255,255,255,0.03);
            transform: rotate(-15deg);
        }

        .stat-label {
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 900;
            margin: 0;
            letter-spacing: -1px;
        }

            .stat-value.success {
                color: #10b981;
            }

        .stat-card.premium {
            background: linear-gradient(135deg, rgba(250, 204, 21, 0.1) 0%, rgba(20, 20, 20, 1) 100%);
            border-color: rgba(250, 204, 21, 0.2);
        }

            .stat-card.premium .stat-value {
                color: var(--gold);
            }

            .stat-card.premium .stat-icon {
                color: rgba(250, 204, 21, 0.05);
            }

        /* AÇÕES RÁPIDAS (TOOLBOX) */
        .toolbox {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 20px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .toolbox-title {
            font-size: 0.9rem;
            font-weight: 700;
            color: #fff;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .toolbox-title i {
                color: var(--gold);
            }

        .btn-action-group {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn-tool {
            background: #1a1a1a;
            color: #fff;
            border: 1px solid var(--border-color);
            padding: 10px 20px;
            border-radius: 12px;
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            transition: 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .btn-tool:hover {
                background: rgba(255,255,255,0.05);
                color: var(--gold);
                border-color: var(--gold);
            }

            .btn-tool.danger:hover {
                background: rgba(255, 59, 48, 0.1);
                color: #ff3b30;
                border-color: rgba(255, 59, 48, 0.3);
            }

        /* FILTROS E TABELA */
        .filter-group {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            overflow-x: auto;
            padding-bottom: 5px;
            align-items: center;
        }

        .btn-filter {
            background: var(--card-bg);
            color: var(--text-muted);
            border: 1px solid var(--border-color);
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            transition: 0.3s;
            white-space: nowrap;
        }

            .btn-filter:hover {
                color: #fff;
                background: rgba(255,255,255,0.05);
            }

            .btn-filter.active {
                background: var(--gold);
                color: #000;
                border-color: var(--gold);
                box-shadow: 0 4px 15px rgba(250, 204, 21, 0.2);
            }

        .table-wrapper {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            overflow: hidden;
        }

        .table {
            margin: 0;
            color: #fff;
            vertical-align: middle;
        }

            .table thead th {
                background: rgba(255,255,255,0.02) !important;
                color: var(--text-muted) !important;
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 1px;
                padding: 15px 20px;
                border-bottom: 1px solid var(--border-color);
                font-weight: 700;
            }

            .table tbody td {
                padding: 15px 20px;
                border-bottom: 1px solid rgba(255,255,255,0.02);
                color: #ccc;
                background: transparent !important;
            }

            .table tbody tr:hover td {
                background: rgba(255,255,255,0.02) !important;
                color: #fff;
            }

        .td-cliente {
            font-weight: 700;
            color: #fff;
        }

        .td-servico {
            color: var(--gold);
            font-weight: 600;
            font-size: 0.9rem;
        }

        .td-data {
            font-size: 0.85rem;
        }

        /* BADGES */
        .status-badge {
            padding: 6px 12px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .badge-success {
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .badge-danger {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        .badge-warning {
            background: rgba(245, 158, 11, 0.1);
            color: #f59e0b;
            border: 1px solid rgba(245, 158, 11, 0.2);
        }

        /* AÇÕES DA TABELA */
        .table-actions {
            display: flex;
            gap: 8px;
            justify-content: center;
        }

        .btn-icon {
            width: 35px;
            height: 35px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid transparent;
            background: rgba(255,255,255,0.05);
            color: #fff;
            transition: 0.3s;
            cursor: pointer;
        }

            .btn-icon.check:hover {
                background: #10b981;
                color: #fff;
                box-shadow: 0 4px 10px rgba(16, 185, 129, 0.3);
            }

            .btn-icon.miss:hover {
                background: #f97316;
                color: #fff;
                box-shadow: 0 4px 10px rgba(249, 115, 22, 0.3);
            }

            .btn-icon.trash:hover {
                background: #ef4444;
                color: #fff;
                box-shadow: 0 4px 10px rgba(239, 68, 68, 0.3);
            }

        form {
            margin: 0;
        }

    </style>
</head>
<body>

    <header class="admin-header">
        <h1 class="admin-title">Painel <span>Admin</span></h1>
        <div class="header-actions">
            <a href="/" class="btn-header"><i class="fas fa-home"></i> <span>Início</span></a>
            <a href="/Login/Sair" class="btn-header" style="color: #ef4444;"><i class="fas fa-sign-out-alt"></i> <span>Sair</span></a>
        </div>
    </header>

    <div class="container mt-4">
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow h-100 border-success border-2">
                    <div class="card-body text-center d-flex flex-column justify-content-center">
                        <h1 class="display-4 text-success mb-3">💰</h1>
                        <h4 class="card-title fw-bold">Gestão Financeira</h4>
                        <p class="card-text text-muted mb-4">Abertura de caixa, lançamentos, comissões e fechamento do dia.</p>
                        <a asp-controller="Caixa" asp-action="Index" class="btn btn-success btn-lg w-100 mt-auto shadow-sm">
                            Acessar Caixa
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card shadow h-100 border-warning border-2">
                    <div class="card-body text-center d-flex flex-column justify-content-center bg-white rounded">
                        <h1 class="display-4 text-warning mb-3">📦</h1>
                        <h4 class="card-title fw-bold text-dark">Controle de Estoque</h4>
                        <p class="card-text text-muted mb-4">Gestão de produtos, alertas de escassez e controle de consumo interno.</p>
                        <a asp-controller="Estoque" asp-action="Index" class="btn btn-warning text-dark fw-bold btn-lg w-100 mt-auto shadow-sm">
                            Acessar Estoque
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="dashboard-container">

        <div class="row g-4 mb-4">
            <div class="col-12 col-md-6 col-xl-3">
                <div class="stat-card">
                    <i class="fas fa-wallet stat-icon"></i>
                    <span class="stat-label">Ganho Hoje (Concluído)</span>
                    <h3 class="stat-value success">@ViewBag.GanhoHoje.ToString("C2")</h3>
                    <small class="text-danger fw-bold mt-2"><i class="fas fa-arrow-down"></i> Gastos: @ViewBag.GastoHoje.ToString("C2")</small>
                </div>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <div class="stat-card">
                    <i class="fas fa-chart-line stat-icon"></i>
                    <span class="stat-label">Ganho da Semana</span>
                    <h3 class="stat-value">@ViewBag.GanhoSemanal.ToString("C2")</h3>
                    <small class="text-danger fw-bold mt-2"><i class="fas fa-arrow-down"></i> Gastos: @ViewBag.GastoSemanal.ToString("C2")</small>
                </div>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <div class="stat-card">
                    <i class="fas fa-calendar-alt stat-icon"></i>
                    <span class="stat-label">Faturamento do Mês</span>
                    <h3 class="stat-value">@ViewBag.GanhoMensal.ToString("C2")</h3>
                    <small class="text-danger fw-bold mt-2"><i class="fas fa-arrow-down"></i> Gastos: @ViewBag.GastoMensal.ToString("C2")</small>
                </div>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <div class="stat-card premium">
                    <i class="fas fa-vault stat-icon"></i>
                    <span class="stat-label">Faturamento Histórico</span>
                    <h3 class="stat-value">@ViewBag.GanhoTotal.ToString("C2")</h3>
                    <small class="text-white-50 mt-2">Total bruto acumulado</small>
                </div>
            </div>
        </div>

        <div class="toolbox">
            <h4 class="toolbox-title"><i class="fas fa-tools"></i> Ações Rápidas</h4>
            <div class="btn-action-group">
                <a href="/Profissional/Index" class="btn-tool" style="border-color: var(--gold); color: var(--gold);">
                    <i class="fas fa-users-cog"></i> Gerenciar Barbeiros
                </a>
                <a asp-action="RelatorioSemanal" class="btn-tool">
                    <i class="fas fa-file-invoice-dollar"></i> Fechamento Semanal
                </a>
                <a asp-action="RelatorioMensal" class="btn-tool">
                    <i class="fas fa-chart-pie"></i> Fechamento Mensal
                </a>
                <a asp-action="Configuracoes" class="btn-tool danger">
                    <i class="fas fa-lock"></i> Bloquear Agenda
                </a>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-3">
            <div class="filter-group align-items-center">
                <a asp-action="PainelPrincipal" asp-route-filtro="futuros" asp-route-dataFiltro="@ViewBag.DataFiltroStr" class="btn-filter @(ViewBag.FiltroAtual == "futuros" ? "active" : "")">Próximos</a>
                <a asp-action="PainelPrincipal" asp-route-filtro="concluidos" asp-route-dataFiltro="@ViewBag.DataFiltroStr" class="btn-filter @(ViewBag.FiltroAtual == "concluidos" ? "active" : "")">Concluídos</a>
                <a asp-action="PainelPrincipal" asp-route-filtro="faltas" asp-route-dataFiltro="@ViewBag.DataFiltroStr" class="btn-filter @(ViewBag.FiltroAtual == "faltas" ? "active" : "")">Não Compareceu</a>

                <div style="position: relative; margin-left: 10px;">
                    <input type="date" id="dataFiltro" class="btn-filter"
                           style="padding-left: 35px; background-color: var(--card-bg); color: #fff; cursor: pointer; border-color: var(--border-color); height: 38px;"
                           value="@ViewBag.DataFiltroStr"
                           onchange="filtrarPorData(this.value, '@ViewBag.FiltroAtual')">
                    <i class="fas fa-calendar-alt" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--gold); pointer-events: none;"></i>
                </div>
            </div>
            <span style="color: var(--text-muted); font-size: 0.85rem; font-weight: 600;">
                <i class="fas fa-list-ol me-1"></i> Total do Dia: <span style="color: #fff;">@Model.Count</span> registros
            </span>
        </div>

        <div class="table-wrapper table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Cliente</th>
                        <th>Serviço</th>
                        <th>Data e Hora</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="td-cliente">
                                    <i class="fas fa-user-circle me-2" style="color: var(--text-muted);"></i>@item.NomeCliente
                                </td>
                                <td>
                                    <div class="td-servico">@item.Servico</div>
                                    <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 2px;">
                                        <i class="fas fa-cut me-1"></i> @item.Profissional
                                    </div>
                                </td>
                                <td class="td-data">
                                    <div style="color: #fff; font-weight: 600;">@item.Data.ToString("dd/MM/yyyy")</div>
                                    <div style="color: var(--text-muted);"><i class="far fa-clock me-1"></i> @item.Horario</div>
                                </td>
                                <td class="text-center">
                                    @if (item.IsConcluido)
                                    {
                                        <span class="status-badge badge-success">Efetivado</span>
                                    }
                                    else if (item.IsFalta)
                                    {
                                        <span class="status-badge badge-danger">Faltou</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge badge-warning">Pendente</span>
                                    }
                                </td>
                                <td>
                                    <div class="table-actions">
                                        @if (!item.IsConcluido && !item.IsFalta)
                                        {
                                            <form asp-action="Concluir" asp-route-id="@item.Id" method="post" title="Marcar como Concluído">
                                                <button type="submit" class="btn-icon check"><i class="fas fa-check"></i></button>
                                            </form>

                                            <form asp-action="MarcarComoFalta" asp-route-id="@item.Id" method="post" title="Cliente Não Compareceu" onsubmit="return confirm('Confirmar que o cliente não compareceu?');">
                                                <button type="submit" class="btn-icon miss"><i class="fas fa-times"></i></button>
                                            </form>

                                            <form asp-action="Excluir" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Tem certeza que deseja apagar este agendamento?');" title="Excluir">
                                                <button type="submit" class="btn-icon trash"><i class="fas fa-trash-alt"></i></button>
                                            </form>
                                        }

                                        @if (item.IsFalta)
                                        {
                                            <form asp-action="Excluir" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Tem certeza que deseja apagar este registro de falta?');" title="Excluir">
                                                <button type="submit" class="btn-icon trash"><i class="fas fa-trash-alt"></i></button>
                                            </form>
                                        }

                                        @if (item.IsConcluido)
                                        {
                                            <span style="color: #10b981; font-size: 0.8rem;"><i class="fas fa-lock"></i> Pago</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="fas fa-box-open mb-3" style="font-size: 2.5rem; color: var(--border-color);"></i>
                                <h5 style="color: var(--text-muted); font-weight: 600;">Nenhum agendamento encontrado para esta data.</h5>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function filtrarPorData(data, filtroAtual) {
            window.location.href = `/Admin/PainelPrincipal?filtro=${filtroAtual || 'futuros'}&dataFiltro=${data}`;
        }
    </script>
</body>
</html>