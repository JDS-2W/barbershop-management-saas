@model List<SistemaBarbearia.Models.AgendamentoModel>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fechamento Semanal | Jadson Barber</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        :root {
            --gold: #FACC15;
            --bg: #050505;
            --card: #141414;
            --border: rgba(255,255,255,0.08);
        }

        body {
            background: var(--bg);
            font-family: 'Inter', sans-serif;
            color: #fff;
            padding: 20px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            border-bottom: 1px solid var(--border);
            padding-bottom: 20px;
        }

        .btn-voltar {
            background: var(--card);
            color: #fff;
            padding: 10px 20px;
            border-radius: 10px;
            text-decoration: none;
            border: 1px solid var(--border);
            font-weight: 600;
        }

            .btn-voltar:hover {
                background: rgba(255,255,255,0.05);
                color: var(--gold);
            }

        .card-dash {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 20px;
        }

        .card-gold {
            background: linear-gradient(135deg, rgba(250, 204, 21, 0.1) 0%, rgba(20, 20, 20, 1) 100%);
            border-color: rgba(250, 204, 21, 0.3);
        }

        .title-sm {
            font-size: 0.8rem;
            color: #888;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 1px;
        }

        .value-lg {
            font-size: 2.5rem;
            font-weight: 900;
            margin: 5px 0 0 0;
        }

        .value-gold {
            color: var(--gold);
        }

        .barber-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 15px;
            margin-bottom: 30px;
        }

        .barber-card {
            background: rgba(255,255,255,0.02);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 15px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .barber-icon {
            background: rgba(250, 204, 21, 0.1);
            color: var(--gold);
            width: 50px;
            height: 50px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }
    </style>
</head>
<body>
    <div class="container" style="max-width: 1000px;">
        <div class="header">
            <div>
                <h2 style="margin: 0; font-weight: 900;"><i class="fas fa-file-invoice-dollar text-warning"></i> Fechamento Semanal</h2>
                <p style="margin: 0; color: #888;">Semana de: <strong>@ViewBag.SemanaReferencia</strong></p>
            </div>
            <a href="/Admin/PainelPrincipal" class="btn-voltar"><i class="fas fa-arrow-left"></i> Voltar</a>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card-dash card-gold">
                    <div class="title-sm">Faturamento da Semana</div>
                    <div class="value-lg value-gold">@ViewBag.TotalSemana.ToString("C2")</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card-dash">
                    <div class="title-sm">Serviços Concluídos</div>
                    <div class="value-lg">@ViewBag.QtdServicos <span style="font-size: 1rem; color: #888; font-weight: 600;">cortes</span></div>
                </div>
            </div>
        </div>

        <h4 style="font-weight: 800; margin-bottom: 15px; border-left: 4px solid var(--gold); padding-left: 10px;">Desempenho da Equipe</h4>
        <div class="barber-grid">
            @if (ViewBag.FaturamentoEquipe != null)
            {
                foreach (var prof in ViewBag.FaturamentoEquipe)
                {
                    <div class="barber-card">
                        <div class="barber-icon"><i class="fas fa-cut"></i></div>
                        <div>
                            <h5 style="margin: 0; font-weight: 800; font-size: 1.1rem;">@prof.Nome</h5>
                            <div style="color: #10b981; font-weight: 800; font-size: 1.2rem;">@prof.TotalGanhos.ToString("C2")</div>
                            <small style="color: #888;">@prof.QuantidadeCortes serviços prestados</small>
                        </div>
                    </div>
                }
            }
        </div>

        <h4 style="font-weight: 800; margin-bottom: 15px; border-left: 4px solid var(--border); padding-left: 10px;">Histórico de Serviços</h4>
        <div class="card-dash" style="padding: 0; overflow: hidden;">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0" style="background: transparent;">
                    <thead>
                        <tr>
                            <th style="background: rgba(255,255,255,0.02); color: #888; border-bottom: 1px solid var(--border);">Data</th>
                            <th style="background: rgba(255,255,255,0.02); color: #888; border-bottom: 1px solid var(--border);">Cliente</th>
                            <th style="background: rgba(255,255,255,0.02); color: #888; border-bottom: 1px solid var(--border);">Serviço</th>
                            <th style="background: rgba(255,255,255,0.02); color: #888; border-bottom: 1px solid var(--border);">Profissional</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td style="border-bottom: 1px solid var(--border);">@item.Data.ToString("dd/MM") às @item.Horario</td>
                                <td style="border-bottom: 1px solid var(--border); font-weight: bold;">@item.NomeCliente</td>
                                <td style="border-bottom: 1px solid var(--border); color: var(--gold);">@item.Servico</td>
                                <td style="border-bottom: 1px solid var(--border);">@item.Profissional</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>